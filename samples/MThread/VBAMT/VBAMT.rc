1            TYPELIB DISCARDABLE     "vbamt.tlb"

#ifndef _MAC
/////////////////////////////////////////////////////////////////////////////
//
// Version
//

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,1,vusVersNumf2,vusVersNuml2
 PRODUCTVERSION vusMajorVer,vusMinorVer,vusVersNumf2,vusVersNuml2
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "Comments", vszMakeDate
            VALUE "CompanyName", "Microsoft Corporation\0"
            VALUE "FileDescription", "VBA MultiThreaded Sample Application\0"
		    VALUE "FileVersion", "1.00." vszVersNum
            VALUE "InternalName", "VBAMT\0"
            VALUE "LegalCopyright", vszCopyright
			VALUE "LegalTrademarks", "APC(TM) is a trademark of Microsoft Corporation. Windows(TM) is a trademark of Microsoft Corporation. Microsoft®, Visual Basic®, and Visual Basic for Applications® are registered trademarks of Microsoft Corporation.\0"
            VALUE "OriginalFilename", "vbamt.EXE\0"
            VALUE "ProductName", "Visual Basic for Applications Software Development Kit\0"
			VALUE "ProductVersion", vszVersNumAll "\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

#endif    // !_MAC

