    LTEXT           "Microsoft Visual Basic(R) for Applications Multi-threaded Application",
                    IDC_ABOUTBOX_APPNAME,49,10,142,17
    ICON            IDI_APP,IDC_STATIC,7,19,20,20
END

IDD_PROJECT DIALOG DISCARDABLE  0, 0, 172, 90
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Microsoft VBAMT"
FONT 8, "MS Sans Serif"
BEGIN
