IDD_MTDIALOG DIALOG DISCARDABLE  0, 0, 341, 201
STYLE WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_MAXIMIZEBOX | WS_MINIMIZEBOX
CAPTION "Microsoft Visual Basic(R) for Applications Multi-threaded Application"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL         "Tab2",IDC_TAB,"SysTabControl32",TCS_RAGGEDRIGHT,9,3,326,
                    179
    PUSHBUTTON      "&Create Thread",IDC_MT1CREATE,251,40,69,21
    PUSHBUTTON      "&Resume Thread",IDC_MT1START,251,77,69,21
    PUSHBUTTON      "&Suspend Thread",IDC_MT1STOP,251,114,69,21
    PUSHBUTTON      "&Destroy Thread",IDC_MT1DESTROY,251,151,69,21
    LTEXT           "Thre&ads",IDC_STATIC,14,23,136,8
    LISTBOX         IDC_MT1LIST,15,40,228,135,LBS_SORT | 
                    LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    LISTBOX         IDC_MT2LIST,15,40,228,135,LBS_SORT | 
                    LBS_NOINTEGRALHEIGHT | NOT WS_VISIBLE | WS_VSCROLL | 
                    WS_TABSTOP
END

