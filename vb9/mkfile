# Plan 9 mkfile for VB9 - Minimal Build Like VB6

</$objtype/mkfile

TARG=formdesigner hello calculator primordial neural-calculator quantum-buttons font-programming

HFILES=\
	include/vb9.h\
	include/controls.h\
	include/neural.h\
	include/quantum.h\
	include/font-coding.h\

OFILES=\
	src/runtime.$O\
	src/controls.$O\
	src/neural.$O\
	src/quantum.$O\
	src/font-coding.$O\

BIN=/bin

# Form designer - the visual IS the program
formdesigner: src/formdesigner.$O $OFILES
	$LD -o $target $prereq

# Hello world example  
hello: examples/hello.$O $OFILES
	$LD -o $target $prereq

# Calculator example
calculator: examples/calculator.$O $OFILES
	$LD -o $target $prereq

# Primordial button - archaeological proof
primordial: examples/primordial.$O $OFILES
	$LD -o $target $prereq

# Neural calculator - forms as neural networks
neural-calculator: examples/neural-calculator.$O $OFILES
	$LD -o $target $prereq

# Quantum buttons - controls in superposition
quantum-buttons: examples/quantum-buttons.$O $OFILES
	$LD -o $target $prereq

# Font programming - typography as executable code
font-programming: examples/font-programming.$O $OFILES
	$LD -o $target $prereq

# Standard Plan 9 build rules
%.$O: %.c
	$CC $CFLAGS $stem.c

install:V: $TARG
	cp $TARG $BIN

clean:V:
	rm -f *.[$OS] $TARG src/*.[$OS] examples/*.[$OS]

nuke:V: clean
	rm -f $TARG